# =============================================================================
# Fake-background framework — git ignore list
# Skip everything that is regenerated by `./run_studies.sh` or contains
# huge / private data.  Keep all source code (.C, .h, .py, .sh, .tex).
# =============================================================================

# ---- ROOT outputs (regenerated; can be > 100 MB each) ----
*.root
*.root.1
*.root.2

# ---- Per-macro per-run outputs ----
**/outputs/
**/outputs/**

# ---- Logs ----
**/log/
**/logs/
*.log
*.out
*.err

# ---- LaTeX build artifacts (Overleaf builds these from .tex) ----
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.idx
*.lof
*.lot
*.nav
*.out
*.pdf            # all top-level PDFs are regenerable
*.snm
*.synctex.gz
*.toc
*.vrb

# ---- LaTeX: keep slides figures (small, lets reviewers see them on GitHub) ----
!slides/figures/
!slides/figures/*.pdf

# ---- Editor / OS noise ----
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.idea/
.vscode/
__pycache__/
*.pyc

# ---- ROOT temp files ----
*.d
*.so
*.pcm
*_C.so
*_C.d
AutoDict_*.cxx

# ---- Backups left by sed -i.bak / vim ----
*.bak
*.orig

# ---- ATLAS asetup state (per-shell, not portable) ----
.asetup.save
**/.asetup.save

# ---- Scratch / debug ----
debug/
